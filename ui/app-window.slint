// Main window: a 3x3 grid of pads mirroring the SPD-SX's layout, each pad
// holding a top and a bottom sample slot. Slots live in one flat model of
// 18 entries indexed (row * 3 + col) * 2, +1 for the bottom slot.

export struct SlotData {
    path: string,
    name: string,
    spectrogram: image,
    has-sample: bool,
    playing: bool,
}

component SampleSlot inherits Rectangle {
    in property <int> idx;
    in property <SlotData> data;
    // Two-way bound to the window's hovered-slot; focus follows the mouse,
    // so whichever slot is under the pointer receives the spacebar.
    in-out property <int> hovered-slot;

    property <bool> hovered: hovered-slot == idx;

    border-radius: 8px;
    background: hovered ? #232b36 : #1b212a;
    border-width: data.playing ? 2px : 1px;
    border-color: data.playing ? #58c47a : (hovered ? #4f8fd9 : #313a46);

    TouchArea {
        changed has-hover => {
            if (self.has-hover) {
                root.hovered-slot = root.idx;
            } else if (root.hovered-slot == root.idx) {
                root.hovered-slot = -1;
            }
        }
    }

    if data.has-sample: Image {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: parent.height - 8px;
        source: data.spectrogram;
        image-fit: fill;
    }
    if data.has-sample: Text {
        x: 8px;
        y: parent.height - self.height - 6px;
        text: data.name;
        color: #cfd8e3;
        font-size: 11px;
    }
    if !data.has-sample: Text {
        text: "drop a .wav";
        color: #4c5866;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
}

export component AppWindow inherits Window {
    title: "SPD-SX Patch Edit";
    preferred-width: 960px;
    preferred-height: 720px;
    background: #12161b;

    in property <[SlotData]> slots;
    in-out property <int> hovered-slot: -1;
    callback toggle-play(int);

    // Layout constants, shared with the geometry math for drop targeting.
    property <length> grid-padding: 14px;
    property <length> grid-spacing: 14px;
    property <length> slot-spacing: 8px;

    forward-focus: keys;
    keys := FocusScope {
        key-pressed(event) => {
            if (event.text == " ") {
                if (root.hovered-slot >= 0) {
                    root.toggle-play(root.hovered-slot);
                }
                return accept;
            }
            reject
        }

        VerticalLayout {
            padding: root.grid-padding;
            spacing: root.grid-spacing;
            for r in 3: HorizontalLayout {
                spacing: root.grid-spacing;
                for c in 3: VerticalLayout {
                    spacing: root.slot-spacing;
                    SampleSlot {
                        idx: (r * 3 + c) * 2;
                        data: root.slots[(r * 3 + c) * 2];
                        hovered-slot <=> root.hovered-slot;
                    }
                    SampleSlot {
                        idx: (r * 3 + c) * 2 + 1;
                        data: root.slots[(r * 3 + c) * 2 + 1];
                        hovered-slot <=> root.hovered-slot;
                    }
                }
            }
        }
    }
}
