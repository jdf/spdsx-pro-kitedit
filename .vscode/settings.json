{
  // clangd is the C++ brain here; keep cpptools from fighting it.
  "C_Cpp.intelliSenseEngine": "disabled",
  // The compile database location lives in each project's .clangd file,
  // so one clangd instance serves every folder of a multi-root workspace.
  "clangd.arguments": ["--header-insertion=never"],
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[objective-cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,
  "files.associations": {
    "*.mm": "objective-cpp"
  },
  // TestMate drives the Testing panel: it finds the built gtest binary and
  // lists every TEST individually, with run/debug buttons in the gutter of the
  // source/*_test.cc that defines it. The glob also picks up the coverage
  // preset's Debug build if that tree exists.
  "testMate.cpp.test.executables": "build*/spdsx_tests_artefacts/*/spdsx_tests",
  // Debug a single test through CodeLLDB (the same debugger as the app).
  "testMate.cpp.debug.configTemplate": {
    "type": "lldb",
    "request": "launch",
    "program": "${exec}",
    "args": "${argsArray}",
    "cwd": "${cwd}",
    "env": "${envObj}"
  },
  // CMake Tools also surfaces ctest entries; leave that off so each test
  // appears once in the Testing panel (TestMate's entries are per-TEST and
  // debuggable).
  "cmake.ctest.testExplorerIntegrationEnabled": false
}
