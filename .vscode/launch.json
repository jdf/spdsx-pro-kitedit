{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "spdsx-patchedit",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/spdsx-patchedit_artefacts/RelWithDebInfo/spdsx-patchedit.app/Contents/MacOS/spdsx-patchedit",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cmake build"
    },
    {
      "name": "spdsx-patchedit (test samples)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/spdsx-patchedit_artefacts/RelWithDebInfo/spdsx-patchedit.app/Contents/MacOS/spdsx-patchedit",
      "args": [
        "--load", "0", "../specgram/test.wav",
        "--load", "9", "../specgram/levels.wav"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cmake build"
    },
    {
      "name": "spdsx_tests",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/spdsx_tests_artefacts/RelWithDebInfo/spdsx_tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build tests"
    },
    {
      "name": "spdsx_tests (filtered)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/spdsx_tests_artefacts/RelWithDebInfo/spdsx_tests",
      "args": ["--gtest_filter=${input:gtestFilter}"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build tests"
    }
  ],
  "inputs": [
    {
      "id": "gtestFilter",
      "type": "promptString",
      "description": "gtest filter, e.g. Layers.* or Protocol.NibbleRoundTrip",
      "default": "*"
    }
  ]
}
